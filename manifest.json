{
  "manifest_version": 3,
  "name": "ADO Notifications",
  "version": "1.0.4",
  "description": "Notifications of assignments and @mentions in Azure DevOps work items and pull requests",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://dev.azure.com/*",
    "https://*.dev.azure.com/*",
    "https://app.vssps.visualstudio.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://dev.azure.com/*", "https://*.dev.azure.com/*"],
      "js": ["src/content/comment-observer.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "16": "icons/icon-16x16.png",
      "32": "icons/icon-32x32.png",
      "48": "icons/icon-48x48.png",
      "128": "icons/icon-128x128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16x16.png",
    "32": "icons/icon-32x32.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  }
}
